{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://tawfeeqmartin.github.io",
          "https://tawfeeqmartin.com",
          "https://www.tawfeeqmartin.com"
        ],
        "methods": [
          "GET",
          "HEAD"
        ],
        "headers": [
          "Range"
        ]
      },
      "exposeHeaders": [
        "Accept-Ranges",
        "Content-Length",
        "Content-Range",
        "ETag"
      ],
      "maxAgeSeconds": 86400
    }
  ]
}
